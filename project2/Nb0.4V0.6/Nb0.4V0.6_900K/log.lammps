# general variables
variable	temperature equal 900 #change this to the temperature of interest
variable	nsteps_run equal 1000000

# general settings
units		metal
dimension 3
boundary	p p p

#processors      3 3 3
atom_style	atomic

# ------------------- ATOM DEFINE ------------------------------

variable        latparam equal 3.14489999999968             #variable

variable        xl equal 0
variable        xh equal 3
variable        yl equal 0
variable        yh equal 3
variable        zl equal 0
variable        zh equal 16

lattice         bcc ${latparam} orient x 1 1 -2 orient y 1 1 1 orient z 1 -1 0
lattice         bcc 3.14489999999968 orient x 1 1 -2 orient y 1 1 1 orient z 1 -1 0
Lattice spacing in x,y,z = 5.1356002 5.4471266 4.4475602
region          mybox block ${xl} ${xh} ${yl} ${yh} ${zl} ${zh}
region          mybox block 0 ${xh} ${yl} ${yh} ${zl} ${zh}
region          mybox block 0 3 ${yl} ${yh} ${zl} ${zh}
region          mybox block 0 3 0 ${yh} ${zl} ${zh}
region          mybox block 0 3 0 3 ${zl} ${zh}
region          mybox block 0 3 0 3 0 ${zh}
region          mybox block 0 3 0 3 0 16

create_box      5 mybox
