# general variables
variable	temperature equal 500       # Temperature variable
variable	nsteps_run equal 1000000

# general settings
units		metal
dimension 3
boundary	p p p

#processors      3 3 3
atom_style	atomic

# ------------------- ATOM DEFINE ------------------------------

variable        latparam equal 3.01685999999993             #variable

variable        xl equal 0
variable        xh equal 3
variable        yl equal 0
variable        yh equal 3
variable        zl equal 0
variable        zh equal 16

lattice         bcc ${latparam} orient x 1 1 -2 orient y 1 1 1 orient z 1 -1 0
lattice         bcc 3.01685999999993 orient x 1 1 -2 orient y 1 1 1 orient z 1 -1 0
Lattice spacing in x,y,z = 4.9265118 5.2253548 4.2664843
region          mybox block ${xl} ${xh} ${yl} ${yh} ${zl} ${zh}
region          mybox block 0 ${xh} ${yl} ${yh} ${zl} ${zh}
region          mybox block 0 3 ${yl} ${yh} ${zl} ${zh}
region          mybox block 0 3 0 ${yh} ${zl} ${zh}
region          mybox block 0 3 0 3 ${zl} ${zh}
region          mybox block 0 3 0 3 0 ${zh}
region          mybox block 0 3 0 3 0 16

create_box      5 mybox
