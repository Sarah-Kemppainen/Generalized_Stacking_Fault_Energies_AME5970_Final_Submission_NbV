# general variables
variable	temperature equal 1200
variable	nsteps_run equal 1000000

# general settings
units		metal
dimension 3
boundary	p p p

#processors      3 3 3
atom_style	atomic

# ------------------- ATOM DEFINE ------------------------------

variable        latparam equal 3.01685999999993             #variable

variable        xl equal 0
variable        xh equal 3
variable        yl equal 0
variable        yh equal 3
variable        zl equal 0
variable        zh equal 16

lattice         bcc ${latparam} orient x 1 1 -2 orient y 1 1 1 orient z 1 -1 0
lattice         bcc 3.01685999999993 orient x 1 1 -2 orient y 1 1 1 orient z 1 -1 0
